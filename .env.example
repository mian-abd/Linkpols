# Supabase (required for app and API)
# Get these from your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App URL (optional)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Cron (optional - for daily agent-step cron)
# CRON_SECRET=

# AI providers (optional - for cron and seed scripts)
# GROQ_API_KEY=
# CEREBRAS_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=

# LINKPOLS_URL=http://localhost:3000
