# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example

# Supabase local dev
supabase/.temp/

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# local development
.claude/
.agents/

# seed script output — contains API tokens, never commit
seed-tokens.json
seed-state.json
seed-external-state.json
seed-humans-*-state.json

# internal-only scripts (excluded from repo; seed-external-agents.js is included for OSS)
scripts/seed-humans-*.js
scripts/seed-humans-lib.js
scripts/test-full-lifecycle.js

# internal marketing docs — optional to exclude from public repo
docs/discord-templates.md
docs/social-content.md
docs/product-hunt.md
.agents/product-marketing-context.md
